#include <stdio.h>
#include <string.h>

void
imprimirflotante(float f) {

  unsigned char *c = (unsigned char *) &f;
  int i;
  unsigned short int result;
  printf("0x");
  for (i = 0; i < (int) sizeof(float); i++) {
    printf("%02x",*(c+i) );
  }
  printf("\n");
}

