#include <stdio.h>
#include "flotante.h"

void imprimirFlotanteBytes(float f) {

	char *c = (char *) &f;
	int i = 0;

	for (i = 0; i < 4; i ++, c++) {
		putchar(*c);
	}
	
	putchar('\n');
}

